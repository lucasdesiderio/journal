---
layout: layouts/base.njk
title: Home
summary: Long-form posts and evergreen pages from the journal.
---
<section class="hero">
  <p class="eyebrow">Journal</p>
  <h1>Thoughtful writing, technical notes, and evergreen pages in one place.</h1>
  <p class="lede">
    Published posts come from <code>blog/posts/</code>. Evergreen pages live in
    <code>blog/pages/</code>. Drafts stay private in <code>blog/drafts/</code>.
  </p>
</section>

<section class="content-grid">
  <div class="content-card content-card-main">
    <div class="section-heading">
      <h2>Posts</h2>
      <p>Published writing sorted newest first.</p>
    </div>
    {% if collections.publishedPosts.length %}
      <ul class="post-list">
        {% for post in collections.publishedPosts %}
          <li>
            <article>
              <p class="meta-label">{{ post.date | readableDate }}</p>
              <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
              {% if post.data.summary %}
                <p>{{ post.data.summary }}</p>
              {% endif %}
              {% if post.data.tags and post.data.tags.length %}
                <ul class="tag-list" aria-label="Tags">
                  {% for tag in post.data.tags %}
                    <li><a class="tag-pill" href="{{ tag | tagUrl }}">{{ tag }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </article>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>No published posts yet.</p>
    {% endif %}
  </div>

  <aside class="content-card content-card-side">
    <div class="section-heading">
      <h2>Pages</h2>
      <p>Evergreen content such as About or Now.</p>
    </div>
    {% if collections.sitePages.length %}
      <ul class="page-list">
        {% for page in collections.sitePages %}
          <li>
            <a href="{{ page.url }}">{{ page.data.title }}</a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>No pages yet.</p>
    {% endif %}

    <div class="section-heading section-heading-spaced">
      <h2>Tags</h2>
      <p>Browse posts by topic.</p>
    </div>
    {% if collections.tagGroups.length %}
      <ul class="page-list">
        {% for tagGroup in collections.tagGroups %}
          <li>
            <a href="{{ tagGroup.tag | tagUrl }}">
              #{{ tagGroup.tag }} <span class="list-count">{{ tagGroup.posts.length }}</span>
            </a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>No tags yet.</p>
    {% endif %}
  </aside>
</section>
